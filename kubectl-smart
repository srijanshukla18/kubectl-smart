#!/usr/bin/env bash
set -euo pipefail

if ! command -v uv >/dev/null 2>&1; then
  echo "Error: uv is required to run kubectl-smart from a checkout." >&2
  echo "" >&2
  echo "Install uv, then retry:" >&2
  echo "  curl -fsSL https://astral.sh/uv/install.sh | sh" >&2
  echo "  ./kubectl-smart --help" >&2
  echo "" >&2
  echo "Or install the current checkout globally:" >&2
  echo "  ./install.sh" >&2
  exit 1
fi

exec uv run --frozen python -c 'import sys; sys.argv[0] = "kubectl-smart"; from kubectl_smart.cli.main import app; app()' "$@"
