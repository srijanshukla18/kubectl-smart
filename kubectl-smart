#!/usr/bin/env python3
"""
kubectl-smart: Intelligent kubectl plugin for Kubernetes debugging

Production-ready modular implementation featuring the bare-bones power trio:
- diag: root-cause analysis of workloads
- graph: dependency visualization with ASCII trees
- top: predictive capacity and certificate outlook
"""

import sys

def main():
    """Main entry point for kubectl-smart"""
    try:
        from kubectl_smart.cli.main import app
        app()
    except ImportError as e:
        print(f"Error: Failed to import kubectl-smart modules: {e}", file=sys.stderr)
        print("\nRun through uv so the locked project dependencies are available:", file=sys.stderr)
        print("  uv run --frozen ./kubectl-smart --help", file=sys.stderr)
        print("\nOr install the current checkout globally:", file=sys.stderr)
        print("  ./install.sh", file=sys.stderr)
        sys.exit(1)
    except Exception as e:
        print(f"Error: {e}", file=sys.stderr)
        sys.exit(1)

if __name__ == "__main__":
    main()
